# PostgreSQL接続URL
# ローカル: postgresql://postgres:password@localhost:5432/million_yoyaku
# Render: Renderダッシュボードの "Internal Database URL" を使用
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# LINE Messaging API (管理者へのPush通知)
# LINE Developers Console で取得: https://developers.line.biz/
LINE_CHANNEL_ACCESS_TOKEN=""
LINE_USER_ID=""

# 管理画面パスワード（未設定の場合は認証スキップ）
ADMIN_PASSWORD="your_admin_password"
